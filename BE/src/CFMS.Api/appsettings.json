{
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_SUPABASE_HOST;Port=5432;Database=postgres;Username=postgres;Password=YOUR_SUPABASE_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },

  "Jwt": {
    "Secret": "REPLACE_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "cfms-api",
    "Audience": "cfms-clients",
    "AccessTokenExpirationMinutes": "60",
    "RefreshTokenExpirationDays": "30"
  },

  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  },

  "SupabaseStorage": {
    "Url": "https://YOUR_PROJECT_REF.supabase.co",
    "SecretKey": "YOUR_SUPABASE_SECRET_KEY",
    "ServiceRoleKey": "",
    "BucketName": "cfms-attachments",
    "PublicBucketUrl": "https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/cfms-attachments"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "FileUpload": {
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".pdf", ".docx", ".xlsx" ]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/cfms-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "AllowedHosts": "*"
}
